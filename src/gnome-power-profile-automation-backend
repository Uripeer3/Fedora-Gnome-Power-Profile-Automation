"""Entrypoint for the GNOME Power Mode Automation system backend."""

from pathlib import Path
import os
import sys


APP = "gnome-power-profile-automation"
SCRIPT_DIR = Path(__file__).resolve().parent
INSTALLED_LIBRARY_DIR = Path(f"/usr/local/libexec/{APP}-backend.d")
LOCAL_LIBRARY_DIR = SCRIPT_DIR / "backend"
INSTALLED_XML = Path(
    "/usr/share/dbus-1/interfaces/io.github.Uripeer3.GnomePowerProfileAutomation1.xml"
)
LOCAL_XML = SCRIPT_DIR.parent / "dbus" / "io.github.Uripeer3.GnomePowerProfileAutomation1.xml"

library_dir = Path(
    os.environ.get(
        "GNOME_POWER_PROFILE_AUTOMATION_BACKEND_LIB_DIR",
        str(LOCAL_LIBRARY_DIR if LOCAL_LIBRARY_DIR.is_dir() else INSTALLED_LIBRARY_DIR),
    )
)
introspection_xml = Path(
    os.environ.get(
        "GNOME_POWER_PROFILE_AUTOMATION_INTROSPECTION_XML",
        str(LOCAL_XML if LOCAL_XML.is_file() else INSTALLED_XML),
    )
)

os.environ["GNOME_POWER_PROFILE_AUTOMATION_INTROSPECTION_XML"] = str(introspection_xml)
sys.path.insert(0, str(library_dir))

from backend_service import main  # noqa: E402


if __name__ == "__main__":
    raise SystemExit(main())
