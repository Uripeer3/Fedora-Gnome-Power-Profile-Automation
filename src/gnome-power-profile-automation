#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-3.0-or-later
# Runtime controller for GNOME Power Mode Automation on Fedora.

set -Eeuo pipefail

APP="gnome-power-profile-automation"
VERSION="1.2.0"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${GNOME_POWER_PROFILE_AUTOMATION_LIB_DIR:-/usr/local/libexec/${APP}.d}"
CONFIG="/etc/${APP}.conf"

DEFAULT_AC_PROFILE="performance"
DEFAULT_BATTERY_PROFILE="balanced"
DEFAULT_LOW_PROFILE="power-saver"
DEFAULT_WARNING_LEVEL="3"
DEFAULT_LID_CLOSE_ON_BATTERY="suspend"
DEFAULT_LID_CLOSE_ON_AC="suspend"

if [[ -t 1 && -z "${NO_COLOR:-}" ]] && command -v tput >/dev/null 2>&1; then
    BOLD="$(tput bold)"
    BLUE="$(tput setaf 4)"
    GREEN="$(tput setaf 2)"
    YELLOW="$(tput setaf 3)"
    RED="$(tput setaf 1)"
    RESET="$(tput sgr0)"
else
    BOLD=""; BLUE=""; GREEN=""; YELLOW=""; RED=""; RESET=""
fi

say() { printf '%s\n' "$*"; }
info() { printf '%sINFO:%s %s\n' "$BLUE" "$RESET" "$*"; }
success() { printf '%sOK:%s %s\n' "$GREEN" "$RESET" "$*"; }
warn() { printf '%sWARNING:%s %s\n' "$YELLOW" "$RESET" "$*" >&2; }
die() { printf '%sERROR:%s %s\n' "$RED" "$RESET" "$*" >&2; logger -t "$APP" -- "ERROR: $*"; exit 1; }
log() { logger -t "$APP" -- "$*"; }
require_root() { (( EUID == 0 )) || die "Run this command with sudo."; }
require_command() { command -v "$1" >/dev/null 2>&1 || die "Missing command: $1"; }

resolve_library() {
    local name="$1" configured_path="${2:-}" installed_path local_path
    installed_path="${LIB_DIR}/${name}"
    local_path="${SCRIPT_DIR}/lib/${name}"

    if [[ -n "$configured_path" && -r "$configured_path" ]]; then
        printf '%s\n' "$configured_path"
    elif [[ -r "$installed_path" ]]; then
        printf '%s\n' "$installed_path"
    elif [[ -r "$local_path" ]]; then
        printf '%s\n' "$local_path"
    else
        die "Missing runtime library: $name"
    fi
}

CONFIG_LIB="$(resolve_library config.sh "${GNOME_POWER_PROFILE_AUTOMATION_CONFIG_LIB:-}")"
POLICY_LIB="$(resolve_library policy.sh "${GNOME_POWER_PROFILE_AUTOMATION_POLICY_LIB:-}")"
PLATFORM_LIB="$(resolve_library platform.sh)"
LID_LIB="$(resolve_library lid.sh)"
MONITOR_LIB="$(resolve_library monitor.sh)"
CLI_LIB="$(resolve_library cli.sh)"

# shellcheck source=lib/config.sh
source "$CONFIG_LIB"
# shellcheck source=lib/policy.sh
source "$POLICY_LIB"
# shellcheck source=lib/platform.sh
source "$PLATFORM_LIB"
# shellcheck source=lib/lid.sh
source "$LID_LIB"
# shellcheck source=lib/monitor.sh
source "$MONITOR_LIB"
# shellcheck source=lib/cli.sh
source "$CLI_LIB"

main() {
    local command="${1:-help}"
    shift || true
    case "$command" in
        configure) require_root; configure "$@" ;;
        status) require_root; show_status ;;
        apply) require_root; load_config; require_ppd_api; apply_policy --force ;;
        sync-lid-policy) require_root; sync_lid_policy ;;
        migrate-config) require_root; migrate_config ;;
        monitor) require_root; monitor ;;
        help|-h|--help) usage ;;
        --version) printf '%s\n' "$VERSION" ;;
        *) die "Unknown command: $command" ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
